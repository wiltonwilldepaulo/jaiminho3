# =============================================================================
# .env.example — ERP Fanorte
# Copie para .env e preencha os valores reais. NUNCA commitar .env.
# =============================================================================

# Application
APP_ENV=production
APP_DEBUG=false
APP_DOMAIN=erp.fanorte.com.br
APP_SECRET=                        # gerar via: openssl rand -hex 32
APP_VERSION=1.0.0
TZ=America/Porto_Velho

# FrankenPHP
FRANKENPHP_NUM_THREADS=8

# PostgreSQL
POSTGRES_DB=erp_fanorte
POSTGRES_USER=erp_app
POSTGRES_PASSWORD=                 # gerar via: openssl rand -base64 32

# Redis
REDIS_PASSWORD=                    # gerar via: openssl rand -base64 32

# Traefik / Cloudflare DNS-01
CF_DNS_API_TOKEN=                  # token API do Cloudflare (escopo Zone:DNS:Edit)
LETSENCRYPT_EMAIL=admin@fanorte.com.br